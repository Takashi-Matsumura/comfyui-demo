# このファイルをコピーして .env.local を作成する:  cp .env.example .env.local

# ComfyUI の HTTP API ベースURL
#   - ローカル開発:            http://localhost:8188
#   - Docker コンテナ → Macホスト: http://host.docker.internal:8188
COMFYUI_BASE_URL=http://localhost:8188

# 使用するチェックポイント（ComfyUI/models/checkpoints/ 配下のファイル名）
COMFYUI_CHECKPOINT=v1-5-pruned-emaonly-fp16.safetensors
